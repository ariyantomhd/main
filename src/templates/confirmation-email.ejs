<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: 'Plus Jakarta Sans', 'Inter', Helvetica, Arial, sans-serif; -webkit-font-smoothing: antialiased;">
    <div class="wrapper" style="background-color: #E0E7FF; padding: 60px 20px; text-align: center;">
        
        <div class="container" style="max-width: 560px; margin: 0 auto; background-color: #ffffff; padding: 48px; border-radius: 32px; border: 1px solid rgba(255, 255, 255, 0.3); text-align: left; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);">
            
            <div class="header" style="text-align: center; padding-bottom: 32px;">
                <a href="https://themavia.com" target="_blank" style="text-decoration: none;">
                    <img 
                        src="https://placehold.co/200x50/31343C/FFFFFF.png?text=LOGO" 
                        alt="Themavia" 
                        width="240" 
                        style="display: block; margin: 0 auto; border: 0; outline: none; height: auto;"
                    >
                </a>
            </div>
            
            <div class="content" style="color: #4A4A68; line-height: 1.8; font-size: 16px;">
                <h1 style="color: #1A1A1A; font-size: 26px; font-weight: 800; margin-bottom: 16px; text-align: center; margin-top: 0;">
                    Hi, <%= username %>! ✨
                </h1>
                
                <p style="text-align: center; margin-bottom: 24px;">
                    Thanks for signing up with <strong>Themavia</strong>. We're excited to have you on board! You're just one step away from exploring our premium DeFi scripts and UI kits.
                </p>
                
                <div style="text-align: center; margin: 40px 0;">
                    <a href="<%= confirmLink %>" style="display: inline-block; background-color: #FFD6FF; color: #4B0082; padding: 18px 36px; text-decoration: none; border-radius: 16px; font-weight: 700; font-size: 15px; border: 2px solid #E7C6FF;">
                        Confirm my email to get started
                    </a>
                </div>
                
                <div style="height: 1px; background-color: #EEEEFF; margin: 30px 0;"></div>
                
                <p style="font-size: 14px; font-weight: 700; color: #1A1A1A; margin-bottom: 12px; margin-top: 0;">
                    Why join Themavia?
                </p>
                <ul style="font-size: 14px; padding-left: 20px; color: #6B7280; margin-top: 0; margin-bottom: 0;">
                    <li style="margin-bottom: 8px;">Access Premium Digital Assets</li>
                    <li style="margin-bottom: 8px;">Lifetime Free Updates</li>
                    <li style="margin-bottom: 0;">Exclusive Developer Community Support</li>
                </ul>

                <p style="margin-top: 30px; font-size: 12px; color: #94A3B8; text-align: center; margin-bottom: 10px;">
                    If the button above doesn't work, copy and paste this link into your browser:
                </p>
                <div style="background-color: #F8F9FA; padding: 12px; border-radius: 10px; font-size: 11px; color: #94a3b8; word-break: break-all; border: 1px dashed #CBD5E1; text-align: center;">
                    <%= confirmLink %>
                </div>
            </div>
            
            <div style="height: 1px; background-color: #EEEEFF; margin: 30px 0;"></div>

            <div style="text-align: center; font-size: 14px; color: #6366F1; font-weight: 600; margin-bottom: 10px;">
                Need help? <a href="mailto:support@themavia.com" style="color: #6366F1; text-decoration: underline;">Contact us anytime.</a>
            </div>

            <div style="text-align: center; color: #94A3B8; font-size: 13px; margin-top: 30px; line-height: 1.5;">
                <strong style="color: #64748B;">Themavia Digital Marketplace</strong><br>
                High-quality resources for modern developers.<br>
                &copy; 2026 Themavia. All rights reserved.
            </div>
        </div>
    </div>
</body>
</html>
